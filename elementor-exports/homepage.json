        {
          "id": "nws00003",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "_title": "News Cards Grid",
            "html": "<style>.park-news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}@media(max-width:768px){.park-news-grid{grid-template-columns:1fr;}}.park-news-card{position:relative;overflow:hidden;border-radius:4px;min-height:340px;display:flex;flex-direction:column;justify-content:flex-end;}.park-news-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;}.park-news-overlay{position:absolute;inset:0;background:rgba(10,20,50,0.52);}.park-news-content{position:relative;z-index:2;padding:24px 20px 20px;}.park-news-title{font-size:22px;font-weight:600;color:#fff;line-height:1.3;text-align:center;margin:0 0 20px;font-family:'Poppins',sans-serif;text-shadow:0 1px 4px rgba(0,0,0,0.4);}.park-news-btn{display:block;background:#FFDA00;color:#1A1A1A;font-size:13px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:14px 20px;text-align:center;border-radius:3px;text-decoration:none;font-family:'Poppins',sans-serif;}.park-news-btn:hover{background:#e5c500;}</style><div class=\"park-news-grid\"><div class=\"park-news-card\"><img src=\"https://parkutoledo.netlify.app/images/news-gcm.jpg\" alt=\"2026 GCM Parking Area Closures\"/><div class=\"park-news-overlay\"></div><div class=\"park-news-content\"><h3 class=\"park-news-title\">2026 GCM Parking<br/>Area Closures</h3><a href=\"/news/\" class=\"park-news-btn\">Click Here</a></div></div><div class=\"park-news-card\"><img src=\"https://parkutoledo.netlify.app/images/news-basketball.jpg\" alt=\"2025/26 Basketball Game Day Info for Permit Holders\"/><div class=\"park-news-overlay\"></div><div class=\"park-news-content\"><h3 class=\"park-news-title\">2025/26<br/>Basketball Game<br/>Day Info for<br/>Permit Holders</h3><a href=\"/holidays-and-global-days/\" class=\"park-news-btn\">Click Here</a></div></div><div class=\"park-news-card\"><img src=\"https://parkutoledo.netlify.app/images/news-parking-updates.jpg\" alt=\"Parking Updates for 2025-26 School Year\"/><div class=\"park-news-overlay\"></div><div class=\"park-news-content\"><h3 class=\"park-news-title\">Parking Updates<br/>for 2025-26 School<br/>Year</h3><a href=\"/news/\" class=\"park-news-btn\">Click Here</a></div></div></div>"
