          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Parking Categories",
            "header_size": "h2",
            "align": "center",
            "title_color": "#0D2352",
            "typography_typography": "custom",
            "typography_font_family": "Poppins",
            "typography_font_size": { "unit": "px", "size": 32, "sizes": [] },
            "typography_font_weight": "600",
            "typography_letter_spacing": { "unit": "em", "size": 0.12, "sizes": [] },
