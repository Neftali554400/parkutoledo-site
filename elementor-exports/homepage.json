        {
          "id": "cat00003",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "_title": "Parking Categories Accordion",
            "html": "<style>.pc-item+.pc-item{border-top:1px solid #c8cdd4}.pc-btn{width:100%;display:flex;align-items:center;justify-content:space-between;padding:20px 24px;background:#e9eaec;border:none;cursor:pointer;font-size:17px;font-weight:400;color:#0D2352;font-family:'Poppins',sans-serif;text-align:left;transition:background 0.15s}.pc-btn:hover{background:#dde0e4}.pc-btn--open{background:#0D2352;color:#fff}.pc-btn--open:hover{background:#0a1e47}.pc-chevron{flex-shrink:0;transition:transform 0.2s}.pc-body{padding:28px 24px 32px;background:#fff}</style><div style=\"border:1px solid #c8cdd4;border-radius:4px;overflow:hidden;\"><div class=\"pc-item\"><button class=\"pc-btn pc-btn--open\" aria-expanded=\"true\" aria-controls=\"pc-permit-body\" onclick=\"togglePC(this)\"><span>Permit Parking</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M18 15l-6-6-6 6\"/></svg></button><div class=\"pc-body\" id=\"pc-permit-body\" style=\"display:block;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/permit-parking/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Parking Permits</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Purchase Daily, Monthly and Fixed Term Permits <a href=\"https://vpermit.com/parkutoledo/\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">Here</a></p></div><div><a href=\"/daily-hourly/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Purchase Hourly</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Parking - Purchase Hourly Parking Through <a href=\"https://parkmobile.io\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">ParkMobile</a></p></div><div><a href=\"/patient-visitor/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Park In Patient Areas</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Register to Park as a Patient at <a href=\"https://www.utmc.com/\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">UTMC</a></p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-visitor-body\" onclick=\"togglePC(this)\"><span>Visitor Parking</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-visitor-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/visitor-parking/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Guest / Visitor Parking</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Purchase a daily visitor permit online or via <a href=\"https://parkmobile.io\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">ParkMobile</a> for hourly parking.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-event-body\" onclick=\"togglePC(this)\"><span>Event Parking</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-event-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/department-event/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Department Event Parking</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Request designated parking for campus events. 72-hour advance notice required.</p></div><div><a href=\"/holidays-and-global-days/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Game Day Parking</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Information for D, C, and K permit holders on home football and basketball game days.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-enforcement-body\" onclick=\"togglePC(this)\"><span>Enforcement &amp; Citations</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-enforcement-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/citations/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Pay or Appeal a Citation</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Enforcement hours: Mon&ndash;Fri 7AM&ndash;10PM, Sat&ndash;Sun 9AM&ndash;5PM. Pay or appeal via <a href=\"https://vpermit.com/parkutoledo/\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">the portal</a>.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-appeals-body\" onclick=\"togglePC(this)\"><span>Appeals</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-appeals-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/citations/#appeals\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Citation Appeals</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Appeals must be filed within 10 calendar days of the citation date. Log in to the Parking Portal to submit your appeal. All decisions are final.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-holidays-body\" onclick=\"togglePC(this)\"><span>Holidays &amp; Global Days</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-holidays-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/holidays-and-global-days/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Parking on University Holidays</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Parking enforcement schedules may vary on university holidays and designated global days.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-guides-body\" onclick=\"togglePC(this)\"><span>User Guides</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-guides-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><a href=\"/user-guides/\" style=\"font-size:16px;font-weight:500;color:#0D2352;text-decoration:underline;display:inline-block;margin-bottom:4px;\">Rules &amp; Regulations</a><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Complete parking rules, violation codes, and fine schedule. <a href=\"https://content.parkutoledo.com/media/kpbbtlt0/parkutoledo-parking-rules-and-regulations.pdf\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">Download PDF</a>.</p></div></div></div></div><div class=\"pc-item\"><button class=\"pc-btn\" aria-expanded=\"false\" aria-controls=\"pc-faqs-body\" onclick=\"togglePC(this)\"><span>Parking FAQs</span><svg class=\"pc-chevron\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><path d=\"M6 9l6 6 6-6\"/></svg></button><div class=\"pc-body\" id=\"pc-faqs-body\" style=\"display:none;\"><div style=\"display:flex;flex-direction:column;gap:24px;\"><div><p style=\"font-size:15px;font-weight:500;color:#0D2352;margin:0 0 4px;\">Do I need a permit on weekends?</p><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Yes. Enforcement is active Saturday&ndash;Sunday 9AM&ndash;5PM in all designated areas.</p></div><div><p style=\"font-size:15px;font-weight:500;color:#0D2352;margin:0 0 4px;\">How do I purchase a permit?</p><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">Log in to the <a href=\"https://vpermit.com/parkutoledo/\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">Parking Portal</a> to purchase daily, monthly, or semester permits.</p></div><div><p style=\"font-size:15px;font-weight:500;color:#0D2352;margin:0 0 4px;\">How do I appeal a citation?</p><p style=\"font-size:15px;color:#1A1A1A;margin:0;line-height:1.6;\">File an appeal within 10 calendar days via the <a href=\"https://vpermit.com/parkutoledo/\" target=\"_blank\" rel=\"noopener\" style=\"color:#0D2352;font-weight:400;text-decoration:underline;\">Parking Portal</a>. Decisions are final.</p></div></div></div></div></div><script>function togglePC(btn){var isOpen=btn.getAttribute('aria-expanded')==='true';document.querySelectorAll('.pc-btn').forEach(function(b){b.setAttribute('aria-expanded','false');b.classList.remove('pc-btn--open');var id=b.getAttribute('aria-controls');if(id)document.getElementById(id).style.display='none';var p=b.querySelector('path');if(p)p.setAttribute('d','M6 9l6 6 6-6');});if(!isOpen){btn.setAttribute('aria-expanded','true');btn.classList.add('pc-btn--open');var id=btn.getAttribute('aria-controls');if(id)document.getElementById(id).style.display='block';var p=btn.querySelector('path');if(p)p.setAttribute('d','M18 15l-6-6-6 6');}}</script>"
          },
          "elements": []
        }
      ]
    },

